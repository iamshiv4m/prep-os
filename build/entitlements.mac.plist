<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Electron's V8 JIT under the hardened runtime. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Needed by Electron's bundled native modules loaded dynamically. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- We only make outbound HTTPS calls (AI providers, RSS feeds, favicons). -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- User-selected file picks (export notes / import plugin JSON). -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
